# Orchestrator settings loaded via dotenv

# Max iterations for Dev/QA loop (default: 3)
MAX_ITERS=3

# Enable RED investigation step (1: enable, 0: disable)
ENABLE_RED_INVESTIGATION=1

# Number of parallel Dev agents (1: FE only, 2: FE+BE)
PARALLEL_DEVS=2

# After replan, automatically run Dev then QA (1: enable, 0: disable)
AUTO_DEV_AFTER_REPLAN=1

# Progress rendering: bar | spinner | none
PROGRESS_STYLE=bar

# Progress refresh interval in ms (default: 120)
PROGRESS_INTERVAL=120

# Overall Codex run timeout in ms (default: 1800000 = 30m)
CODEX_TIMEOUT_MS=1800000

# Stall timeout (no stdout/stderr activity) in ms (default: 300000 = 5m)
CODEX_STALL_TIMEOUT_MS=300000

# Optional: start stage. One of: po | architect | planner | dev | qa | docs
# START_FROM=po

# Optional: suppress noisy console sections (any non-empty value enables)
# PROGRESS_ONLY=

